<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The share extension only writes into the shared App Group inbox (see
	     ShareViewController.copyIntoInbox); the main app does all iCloud work, so the
	     extension needs no iCloud / ubiquity container entitlements. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.tech.inkhorn.pinfold</string>
	</array>
</dict>
</plist>
